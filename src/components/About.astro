---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
import { config } from '../config.ts';
---

<div class="container" vocab="http://schema.org" typeof="Person">
	<meta property="image" content="/images/custom/logo.svg">
	<h1 property="name">{ config.author }</h1>
	<p><span property="knowsAbout">Webdev</span> conservative. <span property="knowsAbout">JS</span> fanatic.</p>
	<p>Proud <b property="jobTitle">Senior Software Engineer / Web Standards Expert</b>.</p>
	<address class="contact-methods">
		<ul class="contact-methods__list">
			{ config.contact.map( ( { label, type, url } ) => {
				return <li property="contactPoint" typeof="ContactPoint"><a href={ url } property={ type }><span property="contactType">{ label }</span></a></li>;
			} ) }
		</ul>
	</address>
</div>

<style>
	.container {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		justify-content: center;
		align-content: center;
		text-align: center;
	}
	h1 {
		margin: 0;
	}
	.contact-methods {
		font-style: normal;

		.contact-methods__list {
			list-style: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-wrap: wrap;
			gap: 1rem;
			flex-direction: column;
			justify-content: center;

			@container ( width >= 70ch ) {
				flex-direction: row;
			}
		}
	}
</style>
